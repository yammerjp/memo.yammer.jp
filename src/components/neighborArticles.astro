---
import type { PostType } from '../types/post'
import styles from './neighborArticles.module.css'

const { prev, next } = Astro.props as { prev: PostType | null; next: PostType | null }
---

<div class={styles.neighborArticles}>
  <div class={styles.neighborArticlesPrevAndNext}>
    {prev === null ? (
      <div class={styles.neighborArticles2prev}></div>
    ) : (
      <a href={'/posts/' + prev.slug} class={styles.neighborArticles2prev}>
        <div class={styles.neighborArticlesPretitle}>
          <img src='/assets/tabler-icon-chevron-left.svg' width='10px' height='10px' alt='left arrow' />
          古い記事
        </div>
        <div class={styles.neighborArticlesTitle}>{prev.title}</div>
      </a>
    )}
    {next === null ? (
      <div class={styles.neighborArticles2next}></div>
    ) : (
      <a href={'/posts/' + next.slug} class={styles.neighborArticles2next}>
        <div class={styles.neighborArticlesPretitle}>
          新しい記事
          <img src='/assets/tabler-icon-chevron-right.svg' width='10px' height='10px' alt='right arrow' />
        </div>
        <div class={styles.neighborArticlesTitle}>{next.title}</div>
      </a>
    )}
  </div>
</div>
