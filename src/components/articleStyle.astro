<style is:global>
  .article-body #footnote-label {
    display: none;
  }

  .article-body a {
    color: #406599;
    text-decoration: none;
    -webkit-tap-highlight-color: transparent;
    -webkit-text-decoration-skip: objects;
    -moz-text-decoration-skip: objects;
    text-decoration-skip: objects;
  }

  .article-body a:hover {
    text-decoration: underline;
  }

  .article-body hr {
    border-top: 1px solid #dddddd;
    border-bottom: 0px;
    border-left: 0px;
    border-right: 0px;
  }

  .article-body img {
    display: block;
    max-width: 100%;
    height: auto;
  }

  .article-body iframe,
  .article-body video,
  .article-body embed,
  .article-body object {
    display: block;
    max-width: 100%;
  }

  .article-body iframe.embed-youtube,
  .article-body iframe.speakerdeck-iframe {
    width: 100% !important;
  }

  .article-body pre {
    font-size: 12px;
    background-color: #f3f3f3;
    border-radius: 12px;
    padding: 12px;
    overflow-x: auto;
  }

  .article-body .twitter-tweet {
    margin: 0 auto;
    padding: 24px 0;
  }

  .article-body .remark-code-title {
    font-size: 12px;
    position: absolute;
    float: left;
    right: -0px;
    padding-top: 12px;
    padding-right: 24px;
    padding-left: 24px;
    margin-right: 12px;
    padding-bottom: 6px;
    background: #ffffff;
    border-radius: 0px 10px 1px 10px;
    border: solid 1px #eeeeee;
  }

  .article-body .remark-code-title:hover {
    opacity: 0.5;
    color: rgba(0, 0, 0, 0);
  }

  .article-body .remark-code-title::selection {
    color: #000000;
    background-color: #ffffff;
  }

  .article-body .hljs {
    background-color: #f3f3f3 !important;
    margin: -12px;
    padding: 12px !important;
  }

  .article-body .footnotes {
    margin-top: 36px;
    border-top: 1px solid #dddddd;
    border-bottom: 1px solid #dddddd;
    font-size: 12px;
    padding-right: 24px;
  }

  .article-body .footnotes hr {
    border: none;
  }

  .article-body .footnotes p {
    margin: 0;
  }

  .article-body blockquote {
    padding: 0.95em;
    border-radius: 6px;
    border-left: 6px solid #fee450;
    background-color: #fbf8e8;
    margin: 12px 0px;
  }

  .article-body blockquote p {
    margin: 0px;
  }

  .article-body h1 {
    margin-top: 60px;
  }

  .article-body h2 {
    margin-top: 48px;
  }

  .article-body h3 {
    margin-top: 36px;
  }

  .article-body h4 {
    margin-top: 24px;
  }

  .article-body ul,
  .article-body ol {
    padding-left: 36px;
  }

  .article-body ul li,
  .article-body ol li {
    padding-left: 12px;
  }

  .article-body table {
    border-spacing: 0;
    border-collapse: collapse;
    display: block;
    width: 100%;
    overflow: auto;
  }

  .article-body table tr {
    border: 0;
  }

  .article-body table th {
    font-weight: 700;
  }

  .article-body table td,
  .article-body table th {
    min-width: 86px;
    padding: 6px 13px;
    border: 1px solid #e6e6e6;
  }

  .article-body table th:empty {
    padding: 0;
    border: 0;
  }

  .article-body p {
    margin: 32px 0px;
  }

  .article-body p,
  .article-body li,
  .article-body a {
    overflow-wrap: anywhere;
    word-break: break-word;
  }
</style>
