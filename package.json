{
  "name": "blog-starter-typescript",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:post-history": "node bin/build-post-history.js",
    "tags:list": "node bin/list-tags.js",
    "dev:astro": "astro dev",
    "build:astro": "astro build",
    "preview:astro": "astro preview",
    "test:astro": "npm run build:post-history && npm run build:astro && vitest --config vitest.integration.config.ts run",
    "format": "prettier --write --ignore-path .gitignore './**/*.{js,jsx,ts,tsx,json,css,scss}'",
    "typecheck": "tsc",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "hast-util-from-html": "^2.0.3",
    "highlight.js": "^11.7.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-code-titles": "^0.1.2",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "retext-stringify": "^4.0.0",
    "strip-markdown": "^6.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/react": "^5.0.6",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.7",
    "astro": "^6.4.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}
